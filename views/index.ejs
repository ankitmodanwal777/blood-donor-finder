<!DOCTYPE html>
<html>
<head>
  <title>Blood Donor Finder</title>
  <style>
    body { font-family: Arial; max-width: 600px; margin: 40px auto; padding: 20px; background: #fdf2f2; }
    h1 { color: #c0392b; text-align: center; }
    h2 { color: #7f1d1d; }
    input, select, button {
      padding: 10px; margin: 6px 0; font-size: 15px; width: 100%;
      box-sizing: border-box; border-radius: 5px; border: 1px solid #ccc;
    }
    button { background: #c0392b; color: white; border: none; cursor: pointer; font-weight: bold; }
    button:hover { background: #922b21; }
    .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
  </style>
</head>
<body>
  <h1>🩸 Blood Donor Finder</h1>

  <div class="card">
    <h2>Register as a Donor</h2>
    <form action="/register" method="POST">
      <input name="name" placeholder="Full Name" required>
      <select name="blood_group" required>
        <option value="">Select Blood Group</option>
        <option>A+</option><option>A-</option>
        <option>B+</option><option>B-</option>
        <option>O+</option><option>O-</option>
        <option>AB+</option><option>AB-</option>
      </select>
      <input name="city" placeholder="City" required>
      <input name="phone" placeholder="Phone Number" required>
      <button type="submit">Register</button>
    </form>
  </div>

  <div class="card" style="margin-top:20px;">
    <h2>Search Donors</h2>
    <form action="/search" method="GET">
      <select name="blood_group" required>
        <option value="">Select Blood Group</option>
        <option>A+</option><option>A-</option>
        <option>B+</option><option>B-</option>
        <option>O+</option><option>O-</option>
        <option>AB+</option><option>AB-</option>
      </select>
      <input name="city" placeholder="City" required>
      <button type="submit">Search</button>
    </form>
  </div>
</body>
</html>
